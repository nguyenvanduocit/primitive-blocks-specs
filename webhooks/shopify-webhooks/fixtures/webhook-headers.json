{
  "_comment": "Sample Shopify webhook HTTP headers for testing. HMAC values are illustrative — compute real values against your SHOPIFY_API_SECRET in tests.",

  "orders_create": {
    "_comment": "Headers for an orders/create delivery",
    "X-Shopify-Topic": "orders/create",
    "X-Shopify-Shop-Domain": "example.myshopify.com",
    "X-Shopify-Webhook-Id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "X-Shopify-Hmac-Sha256": "oMMh/6FS4YHwkNkgLGY3TKa7aCRFRMDnk1gMU7UFMXY=",
    "X-Shopify-Api-Version": "2025-01",
    "Content-Type": "application/json"
  },

  "products_update": {
    "_comment": "Headers for a products/update delivery",
    "X-Shopify-Topic": "products/update",
    "X-Shopify-Shop-Domain": "example.myshopify.com",
    "X-Shopify-Webhook-Id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
    "X-Shopify-Hmac-Sha256": "pNNi/7GT5ZIxOolMHZ4ULb8bDSGSINElk2hNV8VGNYZ=",
    "X-Shopify-Api-Version": "2025-01",
    "Content-Type": "application/json"
  },

  "app_uninstalled": {
    "_comment": "Headers for an app/uninstalled delivery",
    "X-Shopify-Topic": "app/uninstalled",
    "X-Shopify-Shop-Domain": "example.myshopify.com",
    "X-Shopify-Webhook-Id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
    "X-Shopify-Hmac-Sha256": "qOOj/8HU6AJyPpmNIA5VMc9cETHTJOFml3iOW9WHOAZ=",
    "X-Shopify-Api-Version": "2025-01",
    "Content-Type": "application/json"
  },

  "invalid_hmac": {
    "_comment": "Headers with a zeroed-out HMAC — use for HMAC failure tests",
    "X-Shopify-Topic": "orders/create",
    "X-Shopify-Shop-Domain": "example.myshopify.com",
    "X-Shopify-Webhook-Id": "d4e5f6a7-b8c9-0123-defa-234567890123",
    "X-Shopify-Hmac-Sha256": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=",
    "X-Shopify-Api-Version": "2025-01",
    "Content-Type": "application/json"
  },

  "missing_hmac": {
    "_comment": "Headers with no HMAC header — use for missing signature tests",
    "X-Shopify-Topic": "orders/create",
    "X-Shopify-Shop-Domain": "example.myshopify.com",
    "X-Shopify-Webhook-Id": "e5f6a7b8-c9d0-1234-efab-345678901234",
    "X-Shopify-Api-Version": "2025-01",
    "Content-Type": "application/json"
  },

  "unknown_topic": {
    "_comment": "Headers for a topic the app has no registered handler for",
    "X-Shopify-Topic": "inventory_levels/update",
    "X-Shopify-Shop-Domain": "example.myshopify.com",
    "X-Shopify-Webhook-Id": "f6a7b8c9-d0e1-2345-fabc-456789012345",
    "X-Shopify-Hmac-Sha256": "rPPk/9IV7BKzQqnOJB6WNd0dFUIUKPGnm4jPX0XIPB0=",
    "X-Shopify-Api-Version": "2025-01",
    "Content-Type": "application/json"
  },

  "duplicate_delivery": {
    "_comment": "Headers reusing the same webhook_id as orders_create — use for idempotency tests",
    "X-Shopify-Topic": "orders/create",
    "X-Shopify-Shop-Domain": "example.myshopify.com",
    "X-Shopify-Webhook-Id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "X-Shopify-Hmac-Sha256": "oMMh/6FS4YHwkNkgLGY3TKa7aCRFRMDnk1gMU7UFMXY=",
    "X-Shopify-Api-Version": "2025-01",
    "Content-Type": "application/json"
  },

  "_notes": {
    "hmac_algorithm": "HMAC-SHA256",
    "hmac_encoding": "Base64 (standard, not URL-safe)",
    "hmac_key": "SHOPIFY_API_SECRET environment variable",
    "hmac_input": "Raw request body bytes (before any JSON parsing)",
    "webhook_id_format": "UUID v4",
    "topic_format": "resource/action using slash notation (e.g. orders/create, not ORDERS_CREATE)",
    "api_version_format": "YYYY-MM (e.g. 2025-01)",
    "verification_note": "To compute a real HMAC: crypto.createHmac('sha256', secret).update(rawBody).digest('base64')"
  }
}
